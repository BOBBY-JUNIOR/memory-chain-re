# =============================================
# MemoryChain AI — Environment Variables
# Tatum x Walrus Hackathon Edition
# =============================================
# Copy this file to .env.local and fill in your values.

# ─── Tatum API Key ────────────────────────────────────────────────────────────
# REQUIRED for hackathon judging — use Tatum's enterprise Sui RPC nodes.
# Sign up free at: https://dashboard.tatum.io/
# This replaces the public Sui RPC with Tatum's authenticated endpoints:
#   Mainnet: https://sui-mainnet.gateway.tatum.io
#   Testnet: https://sui-testnet.gateway.tatum.io
TATUM_API_KEY="your-tatum-api-key-here"

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL with pgvector extension.
# Supabase free tier works great: https://supabase.com (pgvector included)
DATABASE_URL="postgresql://user:password@localhost:5432/memorychain?schema=public"

# ─── OpenAI / LLM ─────────────────────────────────────────────────────────────
# Required for chat responses + memory extraction + vector embeddings.
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# OpenRouter is supported through the OpenAI-compatible API.
# In Vercel, use OPENROUTER_API_KEY instead of OPENAI_API_KEY.
OPENROUTER_API_KEY="sk-or-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="openai/gpt-4o-mini"
OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
OPENROUTER_APP_NAME="MemoryChain AI"
OPENROUTER_SITE_URL="http://localhost:3000"

# Optional: use any OpenAI-compatible API (Ollama, Together AI, etc.)
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Model to use (gpt-4o-mini is cheap and fast)
OPENAI_MODEL="gpt-4o-mini"

# ─── Sui Blockchain ───────────────────────────────────────────────────────────
# mainnet is preferred for hackathon submission (bonus points!)
# Options: mainnet | testnet | devnet
SUI_NETWORK="mainnet"

# Optional: override Tatum RPC with custom URL
# SUI_RPC_URL="https://sui-mainnet.gateway.tatum.io"

# Your deployed Move contract Package ID.
# Deploy with: cd contracts/memory_registry && sui client publish --gas-budget 100000000
SUI_PACKAGE_ID="0x..."

# ─── Walrus Decentralized Storage ─────────────────────────────────────────────
# Core hackathon requirement: Walrus must be used for real storage.
# Set WALRUS_USE_MOCK=false (or omit it) to use real Walrus.
# Set WALRUS_USE_MOCK=true only for local testing without a Walrus connection.
WALRUS_USE_MOCK="false"

# Mainnet endpoints (used automatically when SUI_NETWORK=mainnet)
WALRUS_PUBLISHER_URL="https://publisher.walrus.space"
WALRUS_AGGREGATOR_URL="https://aggregator.walrus.space"

# ─── Next.js Public Variables (exposed to browser) ────────────────────────────
NEXT_PUBLIC_SUI_NETWORK="mainnet"
NEXT_PUBLIC_WALRUS_AGGREGATOR_URL="https://aggregator.walrus.space"
NEXT_PUBLIC_OPENAI_MODEL="gpt-4o-mini"
NEXT_PUBLIC_OPENROUTER_MODEL="openai/gpt-4o-mini"
NEXT_PUBLIC_TATUM_POWERED="true"

# ─── App ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: https://randomkeygen.com/
NEXTAUTH_SECRET="your-secret-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
